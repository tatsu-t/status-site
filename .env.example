# === Required ===
ADMIN_PASSWORD=changeme
JWT_SECRET=your-secret-key-here
SERVER_URL=https://status.example.com

# === Server ===
PORT=3000

# === Data Storage ===
# DATA_DIR=./data

# === Docker / Local Monitoring ===
# DOCKER_SOCKET=/var/run/docker.sock
# STORAGE_MOUNT_PATH=/mnt/filesystem

# === Backup & Recovery (Optional) ===
# RECOVERY_SECRET=optional-recovery-secret
# BACKUP_RECOVER_URL_1=https://backup1.example.com
# BACKUP_RECOVER_URL_2=https://backup2.example.com
# BACKUP_CONFIG_URLS=https://backup1.example.com/api/admin/config-sync,https://backup2.example.com/api/admin/config-sync
# BACKUP_PUSH_URLS=https://backup1.example.com/api/agent-push,https://backup2.example.com/api/agent-push